<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Encabezado columnas -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:background="#1565C0">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="Fecha"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="13sp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Total"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="13sp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Estado"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="13sp"/>

    </LinearLayout>

    <!-- Lista de pedidos -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_pedidos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="4dp"/>

    <!-- Saldo total -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#FFFFFF"
        android:elevation="8dp">

        <TextView
            android:id="@+id/tv_saldo_total"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Saldo pendiente: L.0.00"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#C62828"/>

        <Button
            android:id="@+id/btn_nueva_compra"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ Nueva compra"
            android:backgroundTint="#1565C0"
            android:textColor="#FFFFFF"/>

    </LinearLayout>

    <!-- Botón marcar pagado -->
    <Button
        android:id="@+id/btn_marcar_pagado"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="✅ Marcar pedido como pagado"
        android:backgroundTint="#2E7D32"
        android:textColor="#FFFFFF"
        android:enabled="false"
        android:layout_margin="8dp"/>

</LinearLayout>